<Window x:Class="ex.Views.ProductForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ex.Views"
        mc:Ignorable="d"
        Title="Products" Height="750" Width="800">

    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Название"/>
            <TextBox x:Name="txtName" Margin="0,5,0,10"/>
            <TextBlock Text="Артикул"/>
            <TextBox x:Name="txtArticle" Margin="0,5,0,10"/>
            <TextBlock Text="Еденица измерения"/>
            <TextBox x:Name="txtUnit" Margin="0,5,0,10"/>
            <TextBlock Text="Цена"/>
            <TextBox x:Name="txtPrice" Margin="0,5,0,10"/>
            <TextBlock Text="Поставщик"/>
            <TextBox x:Name="txtSupplier" Margin="0,5,0,10"/>
            <TextBlock Text="Производитель"/>
            <TextBox x:Name="txtManufacturer" Margin="0,5,0,10"/>
            <TextBlock Text="Категория"/>
            <TextBox x:Name="txtCategory" Margin="0,5,0,10"/>
            <TextBlock Text="Скидка"/>
            <TextBox x:Name="txtDiscount" Margin="0,5,0,10"/>
            <TextBlock Text="Количество"/>
            <TextBox x:Name="txtQuantity" Margin="0,5,0,10"/>
            <TextBlock Text="Описание"/>
            <TextBox x:Name="txtDescription" Margin="0,5,0,10"/>
            <TextBlock Text="Путь к картинке"/>
            <TextBox x:Name="txtImage" Margin="0,5,0,10"/>

            <Button Content="Сохранить" Click="Save_Click" Height="35" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
