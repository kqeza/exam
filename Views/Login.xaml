<Window x:Class="ex.Views.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ex.Views"
        mc:Ignorable="d"
        Title="Login" Height="250" Width="450">
    <Grid>
        <StackPanel Margin="49,30,71,33" Background="#FF3B39F0">
            <TextBlock TextWrapping="Wrap" Margin="10,10,10,10"  TextAlignment="Center" Text="Login" Height="22"/>
            <TextBox x:Name="txtLogin" TextWrapping="Wrap" Text="" Width="120"/>
            <TextBlock TextWrapping="Wrap" Margin="10,10,10,10"  TextAlignment="Center" Text="Password" Height="20"/>
            <PasswordBox x:Name="txtPassword" Width="120"/>
            <Button Content="Войти" Click="BtnLogin_Click" Margin="10,10,10,10" Width="160"/>

            <TextBlock x:Name="txtError" Foreground="Red" Visibility="Collapsed" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>

    </Grid>
</Window>
