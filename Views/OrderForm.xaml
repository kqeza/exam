<Window x:Class="ex.Views.OrderForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ex.Views"
        mc:Ignorable="d"
        Title="OrderForm" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Артикул"/>
            <TextBox x:Name="txtArticle" Margin="0,5,0,10"/>
            <TextBlock Text="Дата"/>
            <DatePicker x:Name="dpOdate" Margin="0,5,0,10"/>
            <TextBlock Text="Дата"/>
            <DatePicker x:Name="dpDdate" Margin="0,5,0,10"/>
            <TextBlock Text="Товар"/>
            <ComboBox x:Name="cboAddress" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,5,0,10"/>
            <TextBlock Text="Партнёр"/>
            <ComboBox x:Name="cboUser" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,5,0,10"/>
            <TextBlock Text="Код"/>
            <TextBox x:Name="txtCode" Margin="0,5,0,10"/>
            <TextBlock Text="Статус"/>
            <TextBox x:Name="txtStatus" Margin="0,5,0,10"/>
            <Button Content="Сохранить" Click="Save_Click" Height="35" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
